        {seq: "개별 시험", idx: 9, item: "사인진동 시험", hours: 300, device: "진동 시험기", condition: "20Hz~2000Hz"},
        {seq: "개별 시험", idx: 10, item: "초기 성능", hours: 24, device: "CVVD 성능 평가 시험기", condition: "상온 상습"}
    ];

    let USER_RELIABILITY_DB = {};
    let addedModelsOrder = []; 
    let globalCalculatedData = [];
    let uniqueIdCounter = 0;

    window.addEventListener('DOMContentLoaded', () => {
        document.getElementById('startDateInput').value = new Date().toISOString().substring(0, 10);
        buildSelectionCheckboxUI();
    });

    function buildSelectionCheckboxUI() {
        const container = document.getElementById('masterItemSelectionContainer');
        if(!container) return;
        container.innerHTML = '';

        let orderedCategories = [];
        MASTER_RELIABILITY_ITEMS.forEach(item => {
            if(!orderedCategories.includes(item.seq)) {
                orderedCategories.push(item.seq);
            }
        });

        orderedCategories.forEach(categoryName => {
            let headerDiv = document.createElement('div');
            headerDiv.className = 'group-header';
            headerDiv.innerHTML = `
                <span>📁 ${categoryName} 전체</span>
                <button class="btn-group-toggle" data-seq="${categoryName}" onclick="toggleGroupItems('${categoryName}', this, event)">선택</button>
            `;
            container.appendChild(headerDiv);

            MASTER_RELIABILITY_ITEMS.forEach((item, index) => {
                if(item.seq === categoryName) {
                    let optionDiv = document.createElement('div');
                    optionDiv.className = 'item-option';
                    optionDiv.setAttribute('data-group-seq', categoryName);
                    optionDiv.innerHTML = `
                        <input type="checkbox" id="chk_${index}" value="${index}" data-group="${categoryName}" onchange="syncToggleButtonText()">
                        <div class="info-text" onclick="triggerCheckboxClick(${index})">
                            <span class="item-name">[${item.idx}] ${item.item}</span>
                            <span class="item-meta">⏳ ${item.hours}h | ⚙️ ${item.device} | 🧬 조건: ${item.condition}</span>
                        </div>
                    `;
                    container.appendChild(optionDiv);
                }
            });
        });
    }

    function triggerCheckboxClick(index) {
        const chk = document.getElementById(`chk_${index}`);
        if(chk) {
            chk.checked = !chk.checked;
            syncToggleButtonText();
        }
    }

    function toggleGroupItems(seqName, btnElement, event) {
        event.preventDefault(); 
        const groupCheckboxes = document.querySelectorAll(`#masterItemSelectionContainer input[type="checkbox"][data-group="${seqName}"]`);
        
        let targetState = false;
        for (let i = 0; i < groupCheckboxes.length; i++) {
            if (!groupCheckboxes[i].checked) {
                targetState = true;
                break;
            }
        }

        groupCheckboxes.forEach(cb => cb.checked = targetState);
        btnElement.innerText = targetState ? "해제" : "선택";
        syncToggleButtonText();
    }

    function toggleAllItems() {
        const checkboxes = document.querySelectorAll('#masterItemSelectionContainer input[type="checkbox"]');
        
        let targetState = false;
        for (let i = 0; i < checkboxes.length; i++) {
            if (!checkboxes[i].checked) {
                targetState = true;
                break;
            }
        }

        checkboxes.forEach(cb => cb.checked = targetState);
        syncToggleButtonText();
    }

    function syncToggleButtonText() {
        const checkboxes = document.querySelectorAll('#masterItemSelectionContainer input[type="checkbox"]');
        const mainBtn = document.getElementById('btnToggleAll');
        if(!mainBtn) return;
        
        let allChecked = true;
        for (let i = 0; i < checkboxes.length; i++) {
            if (!checkboxes[i].checked) {
                allChecked = false;
                break;
            }
        }
        mainBtn.innerText = allChecked ? "❌ 전체 해제" : "☑️ 전체 선택";

        const groupHeaders = document.querySelectorAll('.btn-group-toggle');
        groupHeaders.forEach(btn => {
            const seq = btn.getAttribute('data-seq');
            const gCheckboxes = document.querySelectorAll(`#masterItemSelectionContainer input[type="checkbox"][data-group="${seq}"]`);
            
            let gAllChecked = true;
            for(let j=0; j<gCheckboxes.length; j++) {
                if(!gCheckboxes[j].checked) {
                    gAllChecked = false;
                    break;
                }
            }
            btn.innerText = gAllChecked ? "해제" : "선택";
        });
    }

    function addModelSchedule() {
        const pureModelName = document.getElementById('modelInput').value.trim();
        const step = document.getElementById('stepSelect').value;
        const startDate = document.getElementById('startDateInput').value;

        if(!pureModelName || !startDate) {
            alert("모델명과 시험 시작 일정을 정확히 세팅해 주세요.");
            return;
        }

        const uniqueProjectKey = `${pureModelName} [${step}]`;

        if(addedModelsOrder.includes(uniqueProjectKey)) {
            alert(`[안내] 이미 대기열에 '${uniqueProjectKey}' 스케줄이 존재합니다.`);
            return;
        }

        let selectedTasks = [];
        MASTER_RELIABILITY_ITEMS.forEach((item, index) => {
            const chk = document.getElementById(`chk_${index}`);
            if(chk && chk.checked) {
                selectedTasks.push(JSON.parse(JSON.stringify(item)));
            }
        });

        if(selectedTasks.length === 0) {
            alert("시험 항목 체크박스를 최소 하나 이상 선택해 주세요.");
            return;
        }

        USER_RELIABILITY_DB[uniqueProjectKey] = {
            pureModelName: pureModelName,
            step: step,
            startDate: startDate,
            tasks: selectedTasks
        };

        addedModelsOrder.push(uniqueProjectKey);
        updatePriorityUI();
        recalculateEngine();
    }

    function recalculateEngine() {
        let tempGlobalData = [];
        let modelSequenceEndTimes = {}; 

        addedModelsOrder.forEach(projectKey => {
            const config = USER_RELIABILITY_DB[projectKey];
            const baseStart = new Date(config.startDate + "T00:00:00");
            const sourceList = config.tasks;

            if (!modelSequenceEndTimes[projectKey]) {
                modelSequenceEndTimes[projectKey] = {};
            }

            sourceList.forEach(task => {
                const seqKey = task.seq;
                if (!modelSequenceEndTimes[projectKey][seqKey]) {
                    modelSequenceEndTimes[projectKey][seqKey] = new Date(baseStart.getTime());
                }

                let currentStart = new Date(modelSequenceEndTimes[projectKey][seqKey].getTime());
                let daysNeeded = Math.ceil(task.hours / 24);
                let currentEnd = new Date(currentStart.getTime());
                currentEnd.setDate(currentEnd.getDate() + daysNeeded);

                modelSequenceEndTimes[projectKey][seqKey] = new Date(currentEnd.getTime());

                tempGlobalData.push({
                    id: uniqueIdCounter++,
                    projectKey: projectKey,
                    modelName: config.pureModelName,
                    step: config.step,
                    seq: task.seq,
                    idx: task.idx,
                    item: task.item,
                    device: task.device,
                    condition: task.condition,
                    hours: task.hours,
                    start: currentStart,
                    end: currentEnd,
                    isConflict: false,
                    isBatched: false 
                });
            });
        });

        globalCalculatedData = tempGlobalData;
        validateResourceConflicts();
        renderTableOutput();
    }

    function validateResourceConflicts() {
        globalCalculatedData.forEach(r => {
            r.isConflict = false;
            r.isBatched = false;
        });

        for (let i = 0; i < globalCalculatedData.length; i++) {
            let target = globalCalculatedData[i];
            if (target.condition === "-" || target.condition === "상온 상습") continue;

            let targetStartStr = formatDate(target.start);
            let targetEndStr = formatDate(target.end);

            for (let j = 0; j < globalCalculatedData.length; j++) {
                if (i === j) continue;
                let compare = globalCalculatedData[j];

                if (target.device === compare.device && target.condition.trim() === compare.condition.trim()) {
                    let compareStartStr = formatDate(compare.start);
                    let compareEndStr = formatDate(compare.end);

                    let hasOverlap = targetStartStr < compareEndStr && targetEndStr > compareStartStr;
                    if (hasOverlap) {
                        target.isBatched = true;
                        compare.isBatched = true;
                    }
                }
            }
        }

        for (let i = 0; i < globalCalculatedData.length; i++) {
            let target = globalCalculatedData[i];
            let maxCapacity = EQUIPMENT_CAPACITY[target.device] || 1;
            
            if (maxCapacity >= 900) continue; 

            let simultaneousUseCount = 1;
            let loggedConditionsInPeriod = [target.condition.trim()];

            let targetStartStr = formatDate(target.start);
            let targetEndStr = formatDate(target.end);

            for (let j = 0; j < globalCalculatedData.length; j++) {
                if (i === j) continue;
                let compare = globalCalculatedData[j];

                if (target.device === compare.device) {
                    let compareStartStr = formatDate(compare.start);
                    let compareEndStr = formatDate(compare.end);

                    let hasOverlap = targetStartStr < compareStartStr && targetEndStr > compareStartStr;
                    if (hasOverlap) {
                        const compCond = compare.condition.trim();
                        
                        if (target.condition.trim() === compCond) {
                            continue;
                        }
                        
                        if (!loggedConditionsInPeriod.includes(compCond)) {
                            loggedConditionsInPeriod.push(compCond);
                            simultaneousUseCount++;
                        }
                    }
                }
            }

            if (simultaneousUseCount > maxCapacity) {
                globalCalculatedData.forEach(row => {
                    let rStartStr = formatDate(row.start);
                    let rEndStr = formatDate(row.end);
                    if(row.device === target.device && rStartStr < targetEndStr && rEndStr > targetStartStr && row.condition.trim() !== target.condition.trim()) {
                        row.isConflict = true;
                    }
                });
            }
        }
        
        globalCalculatedData.forEach(r => {
            if (r.isBatched) r.isConflict = false;
        });
    }

    function changePriority(index, direction) {
        let targetIndex = index + direction;
        if (targetIndex < 0 || targetIndex >= addedModelsOrder.length) return;

        let temp = addedModelsOrder[index];
        addedModelsOrder[index] = addedModelsOrder[targetIndex];
        addedModelsOrder[targetIndex] = temp;

        updatePriorityUI();
        recalculateEngine();
    }

    function deleteModel(projectKey) {
        if(confirm(`[${projectKey}] 프로젝트 일정을 전체 삭제하시겠습니까?`)) {
            addedModelsOrder = addedModelsOrder.filter(m => m !== projectKey);
            delete USER_RELIABILITY_DB[projectKey];
            updatePriorityUI();
            recalculateEngine();
        }
    }

    function updatePriorityUI() {
        const container = document.getElementById('priorityListVisual');
        if(!container) return;
        container.innerHTML = '';

        if(addedModelsOrder.length === 0) {
            container.innerHTML = `<li style="font-size:12px; color:#94a3b8; text-align:center; padding:10px;">수립된 프로젝트 스케줄이 없습니다.</li>`;
            return;
        }

        addedModelsOrder.forEach((projectKey, index) => {
            const dbRef = USER_RELIABILITY_DB[projectKey];
            let li = document.createElement('li');
            li.className = 'priority-item';
            li.innerHTML = `
                <div class="model-info">
                    <span class="model-name">순위 ${index + 1}. ${dbRef.pureModelName} [${dbRef.step}]</span>
                    <span style="font-size:11px; color:#64748b;">시작일: ${dbRef.startDate} (${dbRef.tasks.length}개 항목 수립)</span>
                </div>
                <div class="ctrl-btns">
                    <button class="btn-sort" onclick="changePriority(${index}, -1)">▲ 위로</button>
                    <button class="btn-sort" onclick="changePriority(${index}, 1)">▼ 아래로</button>
                    <button class="btn-del" onclick="deleteModel('${projectKey}')">삭제</button>
                </div>
            `;
            container.appendChild(li);
        });
    }

    function updateTableDeviceOverride(id, selectedDevice) {
        const targetRow = globalCalculatedData.find(row => row.id === parseInt(id));
        if (targetRow) {
            const dbList = USER_RELIABILITY_DB[targetRow.projectKey].tasks || [];
            const dbTask = dbList.find(t => t.seq === targetRow.seq && t.idx === targetRow.idx);
            if (dbTask) {
                dbTask.device = selectedDevice;
            }
            recalculateEngine();
        }
    }

    // =========================================================================
    // [v5.4 대전환] 단일 테이블 렌더링에서 -> 모델별 그룹 분리형 멀티 테이블 카드로 개편
    // =========================================================================
    function renderTableOutput() {
        const mainContainer = document.getElementById('dynamicTablesContainer');
        if(!mainContainer) return;
        mainContainer.innerHTML = '';
        
        const deviceOptions = Object.keys(EQUIPMENT_CAPACITY);

        if(addedModelsOrder.length === 0) {
            document.getElementById('resultSection').style.display = 'none';
            return;
        }

        // 우선순위 큐(적재 순서) 마스터 베이스 루프
        addedModelsOrder.forEach(projectKey => {
            const projectData = USER_RELIABILITY_DB[projectKey];
            const projectRows = globalCalculatedData.filter(row => row.projectKey === projectKey);
            
            if(projectRows.length === 0) return;

            // 1. 모델 개별 전용 카드(Card Container) 동적 조립
            const cardDiv = document.createElement('div');
            cardDiv.className = 'project-table-card';
            
            // 2. 카드 헤더 바 (모델 전용 개별 엑셀 다운로드 기능 내장)
            const headerDiv = document.createElement('div');
            headerDiv.className = 'result-header';
            headerDiv.innerHTML = `
                <h3>📋 ${projectData.pureModelName} [${projectData.step}] 단계 시험 스케줄 계획표</h3>
                <button class="btn-download-sub" onclick="downloadSingleProjectCSV('${projectKey}')">📥 이 계획표 전용 엑셀 내보내기</button>
            `;
            cardDiv.appendChild(headerDiv);

            // 3. 모델 전용 반응형 전용 스펙 테이블 조립
            const tableRespDiv = document.createElement('div');
            tableRespDiv.className = 'table-responsive';
            
            const tableHtml = `
                <table>
                    <thead>
                        <tr>
                            <th style="width: 130px;">구분/시퀀스</th>
                            <th style="width: 50px;">순번</th>
                            <th style="width: 200px;">시험 항목</th>
                            <th style="width: 180px;">시험 조건</th>
                            <th style="width: 220px;">지정/투입 설비명 (변경 가능)</th>
                            <th style="width: 70px;">소요(h)</th>
                            <th style="width: 110px;">시작 일자</th>
                            <th style="width: 110px;">완료 일자</th>
                            <th style="width: 140px;">할당 상태 체크</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            `;
            tableRespDiv.innerHTML = tableHtml;
            
            const tbody = tableRespDiv.querySelector('tbody');
            
            // 4. 수집된 소속 행 렌더 버퍼 장입 가동
            projectRows.forEach(row => {
                const tr = document.createElement('tr');
                
                if (row.isConflict) {
                    tr.className = "highlight-conflict";
                } else if (row.isBatched) {
                    tr.className = "highlight-same-condition";
                } else if (row.device.includes("호기")) {
                    tr.className = "highlight-master";
                }

                let selectHtml = `<select class="table-select" onchange="updateTableDeviceOverride('${row.id}', this.value)">`;
                deviceOptions.forEach(dev => {
                    const selected = (dev === row.device) ? 'selected' : '';
                    selectHtml += `<option value="${dev}" ${selected}>${dev}</option>`;
                });
                selectHtml += `</select>`;

                let statusBadgeHtml = '';
                if (row.isConflict) {
                    statusBadgeHtml = `<span class="badge-conflict">⚠️ 자원 부족(충돌)</span>`;
                } else if (row.isBatched) {
                    statusBadgeHtml = `<span class="badge-batch">🔗 동일조건 동시투입</span>`;
                } else {
                    let capacityLimit = EQUIPMENT_CAPACITY[row.device] || 1;
                    let statusText = capacityLimit > 50 ? "제한없음" : "정상할당 (1/" + capacityLimit + ")";
                    statusBadgeHtml = `<span class="badge-ch">${statusText}</span>`;
                }

                tr.innerHTML = `
                    <td class="text-center"><span class="badge-seq">${row.seq}</span></td>
                    <td class="text-center">${row.idx}</td>
                    <td class="text-left" style="font-weight: bold;">${row.item}</td>
                    <td class="text-center"><span class="badge-cond">${row.condition}</span></td>
                    <td class="text-center">${selectHtml}</td>
                    <td class="text-right">${row.hours} h</td>
                    <td class="text-center date-text">${formatDate(row.start)}</td>
                    <td class="text-center date-text">${formatDate(row.end)}</td>
                    <td class="text-center">${statusBadgeHtml}</td>
                `;
                tbody.appendChild(tr);
            });

            cardDiv.appendChild(tableRespDiv);
            mainContainer.appendChild(cardDiv);
        });

        document.getElementById('resultSection').style.display = 'block';
    }

    function formatDate(date) {
        let yyyy = date.getFullYear();
        let mm = String(date.getMonth() + 1).padStart(2, '0');
        let dd = String(date.getDate()).padStart(2, '0');
        return `${yyyy}-${mm}-${dd}`;
    }

    function resetAllScheduler() {
        if(confirm("전체 프로젝트 대기열과 수립된 분리 계획표들을 공백 리셋하시겠습니까?")) {
            globalCalculatedData = [];
            addedModelsOrder = [];
            USER_RELIABILITY_DB = {};
            updatePriorityUI();
            renderTableOutput();
            const checkboxes = document.querySelectorAll('#masterItemSelectionContainer input[type="checkbox"]');
            checkboxes.forEach(cb => cb.checked = false);
            syncToggleButtonText();
        }
    }

    // [New 핵심 기능]: 지정 모델 단독 엑셀 리포트 추출 함수
    function downloadSingleProjectCSV(projectKey) {
        const projectData = USER_RELIABILITY_DB[projectKey];
        const projectRows = globalCalculatedData.filter(row => row.projectKey === projectKey);
        
        if (projectRows.length === 0) return;

        let csvContent = "\uFEFF"; 
        csvContent += `프로젝트, ${projectData.pureModelName} [${projectData.step}] 단계 시험 계획표\n`;
        csvContent += "구분/시퀀스,순번,시험 항목,시험 조건,지정/투입 설비명,소요(h),시작 일자,완료 일자,할당 상태\n";
        
        projectRows.forEach(row => {
            let statusText = row.isConflict ? "자원 부족(충돌)" : (row.isBatched ? "동일조건 동시투입" : "정상할당");
            csvContent += `"${row.seq}","${row.idx}","${row.item}","${row.condition}","${row.device}","${row.hours}","${formatDate(row.start)}","${formatDate(row.end)}","${statusText}"\n`;
        });

        const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.setAttribute("href", url);
        link.setAttribute("download", `Reliability_Plan_${projectData.pureModelName}_${projectData.step}.csv`);
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
</script>

